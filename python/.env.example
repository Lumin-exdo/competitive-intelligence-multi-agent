# ============================================================
# Multi-Agent Competitive Intelligence System - Configuration
# ============================================================
# Copy this file to .env and fill in your values.

# LLM Configuration
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
OPENAI_API_KEY=sk-your-openai-api-key-here
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=ci-agents

# Elasticsearch
ES_URL=http://localhost:9200
ES_INDEX_PREFIX=ci-

# Redis
REDIS_URL=redis://localhost:6379/0

# Notifications
SLACK_WEBHOOK_URL=
DINGTALK_WEBHOOK_URL=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_FROM=
EMAIL_PASSWORD=

# Pipeline Tuning
MONITOR_INTERVAL_MINUTES=60
QUALITY_THRESHOLD=7.0
MAX_REFLEXION_RETRIES=3
